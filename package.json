{
  "name": "bastion-cli",
  "version": "1.0.0",
  "description": "Standalone AI security scanner for LLM applications — The AI watching your AI.",
  "bin": {
    "bastion-cli": "bin/bastion.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "npm run build && node bin/bastion.js",
    "prepublishOnly": "npm run build"
