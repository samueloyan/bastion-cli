    "@babel/traverse": "^7.26.0",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "figures": "^3.2.0",
    "glob": "^10.4.5",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.6",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  }
